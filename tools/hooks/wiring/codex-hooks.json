{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "functions.exec_command|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{HOOKS_DIR}}/pre.js\"",
            "timeout": 30,
            "statusMessage": "Checking pre-tool guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{HOOKS_DIR}}/post.js\"",
            "timeout": 30,
            "statusMessage": "Checking workflow guardrails"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{HOOKS_DIR}}/stop.js\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
