{
  "name": "pythia-workspace",
  "version": "0.3.5",
  "type": "module",
  "description": "AI workspace manager",
  "author": "Serhii Frolov <matochu@gmail.com>",
  "main": "./tools/cli/index.js",
  "bin": {
    "pythia": "./tools/cli/index.js"
  },
  "files": [
    "tools/",
    "assets/",
    "skills/",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "workspace",
    "ai",
    "agents",
    "skills",
    "pythia"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matochu/pythia.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:workflow-doc": "node tools/checks/doc-structure.js tools/fixtures/workflow-docs/valid/*.md",
    "release:check-migrations": "node tools/release/check-migrations.js"
  },
  "dependencies": {
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.8"
  }
}
