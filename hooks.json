{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "functions.exec_command|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/matochu/workspace/ai/pythia/.pythia/runtime/hooks/pre.js\"",
            "timeout": 30,
            "statusMessage": "Checking pre-tool guardrails"
          }
        ],
        "_managed": "pythia"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/matochu/workspace/ai/pythia/.pythia/runtime/hooks/post.js\"",
            "timeout": 30,
            "statusMessage": "Checking workflow guardrails"
          }
        ],
        "_managed": "pythia"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/matochu/workspace/ai/pythia/.pythia/runtime/hooks/stop.js\"",
            "timeout": 30
          }
        ],
        "_managed": "pythia"
      }
    ]
  }
}